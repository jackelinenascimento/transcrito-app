{
  "project": {
    "name": "transcrito-app",
    "type": "python-cli",
    "description": "Ferramenta CLI para transcricao de videos usando Whisper, organizada com principios de Clean Architecture.",
    "language": "Python",
    "pythonVersion": "3.10+",
    "license": "MIT"
  },
  "architecture": {
    "style": "Clean Architecture",
    "dependencyRule": "Camadas externas dependem das internas; o dominio nao depende de frameworks, CLI ou Whisper.",
    "flow": [
      "src/main.py",
      "src/interfaces/cli/commands.py",
      "src/application/transcribe_video.py",
      "src/domain/transcription_service.py",
      "src/infrastructure/whisper_transcription_service.py",
      "src/domain/transcription.py",
      "src/application/formatters/timestamp_formatter.py",
      "src/application/formatters/srt_formatter.py",
      "src/application/writers/file_writer.py",
      "outputs/*.txt"
    ]
  },
  "entrypoints": [
    {
      "path": "src/main.py",
      "command": "python -m src.main <video>",
      "responsibility": "Inicializa o servico Whisper e delega a execucao para a interface CLI."
    }
  ],
  "dependencies": {
    "python": [
      { "name": "openai-whisper", "version": ">=20231117", "purpose": "Motor de transcricao de audio/video." },
      { "name": "torch", "purpose": "Backend usado pelo Whisper para inferencia." }
    ],
    "system": [
      { "name": "ffmpeg", "purpose": "Processamento e leitura de arquivos de midia usados pelo Whisper." }
    ]
  },
  "directories": [
    { "path": "src", "type": "source", "responsibility": "Codigo-fonte principal da aplicacao." },
    {
      "path": "src/domain",
      "type": "domain-layer",
      "responsibility": "Modelos e contratos centrais.",
      "files": [
        { "path": "src/domain/transcription.py", "responsibility": "Define as entidades Transcription e TranscriptionSegment." },
        { "path": "src/domain/transcription_service.py", "responsibility": "Contrato abstrato para servicos de transcricao." },
        { "path": "src/domain/transcription_errors.py", "responsibility": "Excecoes especificas para transcricao." }
      ]
    },
    {
      "path": "src/application",
      "type": "application-layer",
      "responsibility": "Casos de uso e formatadores.",
      "files": [
        { "path": "src/application/transcribe_video.py", "responsibility": "Caso de uso principal." }
      ],
      "subdirectories": [
        {
          "path": "src/application/formatters",
          "files": [
            { "path": "src/application/formatters/base_formatter.py" },
            { "path": "src/application/formatters/timestamp_formatter.py" },
            { "path": "src/application/formatters/srt_formatter.py" }
          ]
        },
        { "path": "src/application/writers", "files": [ { "path": "src/application/writers/file_writer.py" } ] }
      ]
    },
    {
      "path": "src/infrastructure",
      "type": "infrastructure-layer",
      "responsibility": "Implementacoes concretas.",
      "files": [
        { "path": "src/infrastructure/whisper_transcription_service.py" },
        { "path": "src/infrastructure/diarization_provider.py" }
      ]
    },
    { "path": "src/interfaces", "type": "adapters", "files": [ { "path": "src/interfaces/cli/commands.py" } ] },
    { "path": "docs", "type": "documentation" },
    { "path": "scripts", "type": "automation" },
    { "path": "outputs", "type": "generated-output" },
    { "path": "videos", "type": "input-assets" }
  ],
  "importantFiles": [
    { "path": "README.md" },
    { "path": "requirements.txt" },
    { "path": "requirements-diarization.txt" },
    { "path": ".gitignore" }
  ],
  "runtimeBehavior": {
    "input": "Caminho de um arquivo de video recebido por argumento posicional.",
    "output": "Arquivo .txt criado no diretorio informado por --out, ou em outputs por padrao.",
    "defaultModel": "Whisper base",
    "device": "CPU",
    "language": "pt",
    "defaultFormatter": "TimestampFormatter"
  },
  "generatedOrLocalOnly": [
    { "path": ".venv" },
    { "path": "venv" },
    { "path": ".idea" },
    { "path": "outputs" }
  ],
  "extensionPoints": [
    { "name": "Novo motor de transcricao" },
    { "name": "Novo formato de saida" },
    { "name": "Nova estrategia de escrita" },
    { "name": "Novos comandos CLI" }
  ]
}

